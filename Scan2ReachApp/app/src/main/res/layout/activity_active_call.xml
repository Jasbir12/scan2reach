<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gray_900">

    <TextView
        android:id="@+id/tvCallStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Connected"
        android:textSize="18sp"
        android:textColor="@color/success"
        android:layout_marginTop="80dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvCallerIcon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📞"
        android:textSize="80sp"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toBottomOf="@id/tvCallStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvCallerName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Caller Name"
        android:textSize="28sp"
        android:textColor="@color/white"
        android:fontFamily="sans-serif-medium"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/tvCallerIcon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvVehicleNumber"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Vehicle Number"
        android:textSize="16sp"
        android:textColor="@color/white"
        android:alpha="0.8"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvCallerName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvCallDuration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="00:00"
        android:textSize="48sp"
        android:textColor="@color/white"
        android:fontFamily="sans-serif-light"
        android:layout_marginTop="48dp"
        app:layout_constraintTop_toBottomOf="@id/tvVehicleNumber"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="100dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageButton
            android:id="@+id/btnMute"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/ic_mic"
            android:background="@drawable/circle_button"
            android:backgroundTint="@color/gray_700"
            android:contentDescription="Mute"
            android:layout_marginEnd="20dp" />

        <Button
            android:id="@+id/btnEndCall"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:text="✕"
            android:textSize="32sp"
            android:textColor="@color/white"
            android:backgroundTint="@color/error"
            app:cornerRadius="40dp" />

        <ImageButton
            android:id="@+id/btnSpeaker"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/ic_volume_up"
            android:background="@drawable/circle_button"
            android:backgroundTint="@color/gray_700"
            android:contentDescription="Speaker"
            android:layout_marginStart="20dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>