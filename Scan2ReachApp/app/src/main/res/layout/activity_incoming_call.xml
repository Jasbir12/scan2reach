<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary">

    <TextView
        android:id="@+id/tvIncomingCall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Incoming Call"
        android:textSize="20sp"
        android:textColor="@color/white"
        android:layout_marginTop="80dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvCallerIcon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📞"
        android:textSize="80sp"
        android:layout_marginTop="60dp"
        app:layout_constraintTop_toBottomOf="@id/tvIncomingCall"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvCallerName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Unknown Caller"
        android:textSize="28sp"
        android:textColor="@color/white"
        android:fontFamily="sans-serif-medium"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/tvCallerIcon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvVehicleNumber"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Vehicle: DL01AB1234"
        android:textSize="18sp"
        android:textColor="@color/white"
        android:alpha="0.9"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvCallerName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvCallType"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🚨 EMERGENCY CALL"
        android:textSize="16sp"
        android:textColor="@color/white"
        android:visibility="gone"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvVehicleNumber"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="80dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btnReject"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:text="✕"
            android:textSize="32sp"
            android:textColor="@color/white"
            android:backgroundTint="@color/error"
            app:cornerRadius="40dp"
            android:layout_marginEnd="40dp" />

        <Button
            android:id="@+id/btnAccept"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:text="✓"
            android:textSize="32sp"
            android:textColor="@color/white"
            android:backgroundTint="@color/success"
            app:cornerRadius="40dp"
            android:layout_marginStart="40dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>