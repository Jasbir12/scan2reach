rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ========================================================================
    // HELPER FUNCTIONS
    // ========================================================================
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if user owns this document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Check if user is admin (by checking admins collection)
    function isAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    // Check if user is super admin
    function isSuperAdmin() {
      return isAdmin() && 
             get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'super_admin';
    }
    
    // ✅ NEW: Check if user has active subscription
    function hasActiveSubscription(userId) {
      let userDoc = get(/databases/$(database)/documents/users/$(userId));
      return userDoc.exists && 
             userDoc.data.subscription.status == 'active' &&
             userDoc.data.subscription.expiryDate > now;
    }
    
    // Check if profile belongs to user
    function isProfileOwner() {
      return isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    // Check if profile is active
    function isProfileActive() {
      return resource.data.subscriptionStatus == 'active';
    }
    
    // ========================================================================
    // ADMINS COLLECTION
    // ========================================================================
    
    match /admins/{adminId} {
      // Admins can read all admin docs
      allow read: if isAdmin();
      
      // User can read their own admin doc
      allow read: if isOwner(adminId);
      
      // FIRST ADMIN SETUP: Allow if no admins exist yet OR user creates their own
      // This allows initial setup, then only super_admin can add more
      allow create: if isAuthenticated() && 
                       request.auth.uid == adminId &&
                       request.resource.data.uid == adminId &&
                       request.resource.data.keys().hasAll(['uid', 'email', 'role']);
      
      // Only super_admin can update admin docs
      allow update: if isSuperAdmin();
      
      // Only super_admin can delete (but not themselves)
      allow delete: if isSuperAdmin() && request.auth.uid != adminId;
    }
    
    // ========================================================================
    // USERS COLLECTION - With Subscription Enforcement
    // ========================================================================
    
    match /users/{userId} {
      // User can read their own doc, admins can read all
      allow read: if isOwner(userId) || isAdmin();
      
      // User can create their own doc
      allow create: if isOwner(userId) &&
                       request.resource.data.uid == userId;
      
      // User can update their own doc, admin can update any
      allow update: if isOwner(userId) || isAdmin();
      
      // Only admin can delete
      allow delete: if isAdmin();
    }
    
    // ========================================================================
    // PROFILES COLLECTION - With Subscription Validation
    // ========================================================================
    
    match /profiles/{profileId} {
      // PUBLIC: Only active profiles can be read (for QR scanning)
      allow read: if isProfileActive();
      
      // Owner can always read their own profiles
      allow read: if isProfileOwner();
      
      // Admin can read all profiles
      allow read: if isAdmin();
      
      // ✅ CRITICAL: Only users with active subscription can create/update profiles
      allow create: if isAuthenticated() &&
                       hasActiveSubscription(request.auth.uid) &&
                       request.resource.data.userId == request.auth.uid &&
                       request.resource.data.keys().hasAll(['userId', 'productType']);
      
      // ✅ CRITICAL: Only subscribed users can update their profiles
      allow update: if (isProfileOwner() &&
                       hasActiveSubscription(request.auth.uid) &&
                       request.resource.data.userId == resource.data.userId) ||
                      isAdmin();
      
      // Owner or admin can delete
      allow delete: if isProfileOwner() || isAdmin();
    }
    
    // ========================================================================
    // CALL REQUESTS COLLECTION - Dual Profile Routing
    // ========================================================================
    
    match /callRequests/{callId} {
      // ✅ IMPORTANT: Only subscribed users can receive calls
      allow read: if (isAuthenticated() && 
                      hasActiveSubscription(request.auth.uid) &&
                      get(/databases/$(database)/documents/profiles/$(resource.data.profileId)).data.userId == request.auth.uid) ||
                     isAdmin();
      
      // ✅ Backend/Frontend can create call requests
      allow create: if request.resource.data.keys().hasAll(['profileId', 'callerName', 'callType']);
      
      // Can update own calls
      allow update: if isAdmin();
      
      allow delete: if isAdmin();
    }
    
    // ========================================================================
    // CALL LOGS COLLECTION - Analytics with Call Type
    // ========================================================================
    
    match /callLogs/{logId} {
      // ✅ IMPORTANT: Only subscribed users can read their call logs
      allow read: if (isAuthenticated() && 
                      hasActiveSubscription(request.auth.uid) &&
                      resource.data.userId == request.auth.uid) ||
                     isAdmin();
      
      // Backend/Functions only
      allow create, update: if false;
      allow delete: if isAdmin();
    }
    
    // ========================================================================
    // FCM TOKENS COLLECTION - Device Mode Support
    // ========================================================================
    
    match /fcmTokens/{tokenId} {
      // User can read their own tokens
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      // Admin can read all
      allow read: if isAdmin();
      
      // Users can create/update their own tokens
      allow create, update: if isAuthenticated() && 
                              request.resource.data.userId == request.auth.uid;
      
      // Only admin can delete
      allow delete: if isAdmin();
    }
    
    // ========================================================================
    // SETTINGS COLLECTION
    // ========================================================================
    
    match /settings/{documentId} {
      // Anyone can read settings (pricing, plans, etc.)
      allow read: if true;
      
      // Only admin can write
      allow write: if isAdmin();
    }
    
    // ========================================================================
    // PAYMENTS COLLECTION
    // ========================================================================
    
    match /payments/{paymentId} {
      // User can read their own payments, admin can read all
      allow read: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isAdmin();
      
      // Authenticated users can create payment records
      allow create: if isAuthenticated() &&
                       request.resource.data.userId == request.auth.uid;
      
      // Only admin/cloud functions can update
      allow update: if isAdmin();
      
      // Only admin can delete
      allow delete: if isAdmin();
    }
    
    // ========================================================================
    // ORDERS COLLECTION
    // ========================================================================
    
    match /orders/{orderId} {
      // User can read their own orders, admin can read all
      allow read: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isAdmin();
      
      // Authenticated users can create
      allow create: if isAuthenticated() &&
                       request.resource.data.userId == request.auth.uid;
      
      // User can update their own, admin can update any
      allow update: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isAdmin();
      
      // Only admin can delete
      allow delete: if isAdmin();
    }
    
    // ========================================================================
    // CALLS COLLECTION (LEGACY - Keep for backward compatibility)
    // ========================================================================
    
    match /calls/{callId} {
      // Participants can read
      allow read: if isAuthenticated() &&
                     (resource.data.senderId == request.auth.uid ||
                      resource.data.receiverId == request.auth.uid) ||
                     isAdmin();
      
      // Authenticated can create
      allow create: if isAuthenticated();
      
      // Owner or admin can update
      allow update: if isAuthenticated() &&
                       (resource.data.senderId == request.auth.uid ||
                        resource.data.receiverId == request.auth.uid) ||
                       isAdmin();
      
      // Owner or admin can delete
      allow delete: if isAuthenticated() &&
                       (resource.data.senderId == request.auth.uid ||
                        resource.data.receiverId == request.auth.uid) ||
                       isAdmin();
    }
    
    // ========================================================================
    // ANALYTICS & LOGS (READ-ONLY)
    // ========================================================================
    
    match /analytics/{documentId} {
      allow read: if isAdmin() || 
                     (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow write: if false;
    }
    
    match /profileViews/{documentId} {
      allow read: if isAdmin();
      allow write: if false;
    }
    
    match /emergencyLogs/{documentId} {
      allow read: if isAdmin() ||
                     (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow write: if false;
    }
  }
}
      allow read: if isAuthenticated() &&
                    (resource.data.callerId == request.auth.uid ||
                     resource.data.receiverId == request.auth.uid ||
                     isAdmin());
      
      // Authenticated users can create calls
      allow create: if isAuthenticated();
      
      // Participants can update (for status changes)
      allow update: if isAuthenticated() &&
                      (resource.data.callerId == request.auth.uid ||
                       resource.data.receiverId == request.auth.uid ||
                       isAdmin());
      
      // Admin can delete
      allow delete: if isAdmin();
    }
    
    // ========================================================================
    // CALL REQUESTS COLLECTION (WebRTC Signaling)
    // ========================================================================
    
    match /callRequests/{callId} {
      // Participants can read
      allow read: if isAuthenticated() &&
                    (resource.data.callerId == request.auth.uid ||
                     resource.data.ownerId == request.auth.uid ||
                     isAdmin());
      
      // Authenticated users can create
      allow create: if isAuthenticated() &&
                       request.resource.data.callerId == request.auth.uid;
      
      // Participants can update
      allow update: if isAuthenticated() &&
                      (resource.data.callerId == request.auth.uid ||
                       resource.data.ownerId == request.auth.uid);
      
      // Participants can delete
      allow delete: if isAuthenticated() &&
                      (resource.data.callerId == request.auth.uid ||
                       resource.data.ownerId == request.auth.uid);
      
      // ICE Candidates subcollection
      match /candidates/{candidateId} {
        allow read, write: if isAuthenticated();
      }
    }
    
    // ========================================================================
    // SCANS COLLECTION (Analytics)
    // ========================================================================
    
    match /scans/{scanId} {
      // Authenticated users can read
      allow read: if isAuthenticated();
      
      // Anyone can create scan record (public QR scanning)
      allow create: if true;
      
      // No updates or deletes (immutable logs)
      allow update, delete: if isAdmin();
    }
    
    // ========================================================================
    // ADMIN LOGS COLLECTION
    // ========================================================================
    
    match /admin_logs/{logId} {
      // Only admins can read
      allow read: if isAdmin();
      
      // Authenticated users can create (for logging their actions)
      allow create: if isAuthenticated();
      
      // Only admin can update/delete
      allow update, delete: if isAdmin();
    }
    
    // ========================================================================
    // FAILED PAYMENTS COLLECTION
    // ========================================================================
    
    match /failed_payments/{docId} {
      // Only admin can read
      allow read: if isAdmin();
      
      // Authenticated users can create (for logging failures)
      allow create: if isAuthenticated();
      
      // No updates/deletes
      allow update, delete: if isAdmin();
    }
    
    // ========================================================================
    // WEBHOOK LOGS COLLECTION
    // ========================================================================
    
    match /webhook_logs/{logId} {
      // Only admin can read
      allow read: if isAdmin();
      
      // Anyone can create (webhooks don't have auth)
      allow create: if true;
      
      // No updates/deletes
      allow update, delete: if isAdmin();
    }
    
    // ========================================================================
    // RATE LIMITS COLLECTION
    // ========================================================================
    
    match /rateLimits/{limitId} {
      // Only admin can access
      allow read, write: if isAdmin();
    }
    
    // ========================================================================
    // PRODUCTS COLLECTION (Legacy - for backwards compatibility)
    // ========================================================================
    
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // ========================================================================
    // PLANS COLLECTION (Legacy - for backwards compatibility)
    // ========================================================================
    
    match /plans/{planId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // ========================================================================
    // FCM TOKENS (for push notifications)
    // ========================================================================
    
    match /fcmTokens/{tokenId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create, update: if isAuthenticated() && 
                               request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
  }
}